modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 5173

[[ports]]
localPort = 19164
externalPort = 4200

[[ports]]
localPort = 19433
externalPort = 3000

[[ports]]
localPort = 21283
externalPort = 3002

[[ports]]
localPort = 21393
externalPort = 3001

[[ports]]
localPort = 25766
externalPort = 3003

[nix]
channel = "stable-25_05"
